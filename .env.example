# Example environment variables for gestion_data_ia
# Copy to .env and fill with real values (DO NOT commit secrets)

# Flask / Django secret key or generic app secret
SECRET_KEY=changeme

# Database (e.g., Postgres) URL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Supabase (if used)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key

# Render / deployment related
RENDER_SERVICE_ID=
